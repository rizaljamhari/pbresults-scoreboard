{
  "name": "pbresults-scoreboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "type": "module",
  "scripts": {
    "setup:portable": "pnpm install && pnpm build",
    "package:windows:portable": "node scripts/package-windows-portable.mjs",
    "dev": "node scripts/dev-launch.mjs",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "start:open": "open http://localhost:3000/admin/operations && pnpm start",
    "test": "vitest run",
    "check:overlay-scope": "node scripts/check-overlay-tailwind.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.0.4",
    "@fontsource/barlow-condensed": "^5.1.1",
    "@fontsource/bebas-neue": "^5.1.1",
    "@fontsource/oswald": "^5.1.1",
    "@imgly/background-removal-node": "^1.4.5",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "fastify": "^5.2.1",
    "lucide-react": "^0.511.0",
    "mime-types": "^2.1.35",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-rnd": "^10.5.2",
    "react-router-dom": "^7.6.0",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.15.17",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "onnxruntime-node"
    ],
    "ignoredBuiltDependencies": [
      "onnxruntime-node",
      "sharp"
    ]
  }
}
